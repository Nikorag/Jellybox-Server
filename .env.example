# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (pooled)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# Neon direct connection string (used by Prisma for migrations)
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# NextAuth v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
# Base URL of the application
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Generic OIDC / SSO provider (optional).
# Leave blank to disable. If all three (issuer, id, secret) are set, a
# "Continue with <AUTH_OIDC_NAME>" button appears on the sign-in and
# sign-up pages. The issuer must support OIDC discovery at
# <issuer>/.well-known/openid-configuration. The callback URL to whitelist
# with your IdP is: <AUTH_URL>/api/auth/callback/oidc
AUTH_OIDC_ISSUER=""
AUTH_OIDC_ID=""
AUTH_OIDC_SECRET=""
AUTH_OIDC_NAME="SSO"

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to hide the "Continue with Google" button and skip the Google
# provider entirely, even if AUTH_GOOGLE_ID/SECRET are set.
AUTH_DISABLE_GOOGLE="false"

# Set to "true" to disable account creation. The /auth/signup page will
# redirect to /auth/signin and the sign-up server action will reject requests.
AUTH_DISABLE_SIGNUP="false"

# Set to "true" to hide the marketing landing page and self-hosting docs from
# unauthenticated users — useful for private deployments. Signed-in users
# continue to the dashboard; everyone else gets redirected to /auth/signin.
DISABLE_PUBLIC_PAGES="false"

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM (encrypt Jellyfin API tokens at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JELLYFIN_ENCRYPTION_KEY="your-64-char-hex-key-here"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com — used for email verification and password reset
RESEND_API_KEY="re_your_resend_api_key"
# Verified sender domain/address in Resend
EMAIL_FROM="Jellybox <noreply@yourdomain.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Jellybox Server"
