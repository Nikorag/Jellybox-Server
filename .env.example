# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (pooled)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# Neon direct connection string (used by Prisma for migrations)
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# NextAuth v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
# Base URL of the application
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com)
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM (encrypt Jellyfin API tokens at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JELLYFIN_ENCRYPTION_KEY="your-64-char-hex-key-here"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com — used for email verification and password reset
RESEND_API_KEY="re_your_resend_api_key"
# Verified sender domain/address in Resend
EMAIL_FROM="Jellybox <noreply@yourdomain.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Jellybox Server"
