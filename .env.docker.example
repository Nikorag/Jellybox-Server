# Minimum environment for the docker-compose stack. Copy to .env and fill in.
#
#   cp .env.docker.example .env
#
# DATABASE_URL / DIRECT_URL are managed by docker-compose.yml — don't set them
# here. AUTH_URL defaults to http://localhost:3000; override if you reverse-
# proxy Jellybox behind a public domain.

# ─── Required ────────────────────────────────────────────────────────────────

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# 64-char hex (32 bytes). Encrypts Jellyfin tokens AND extension-OAuth state.
# NEVER change this in production — rotating invalidates every stored token.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JELLYFIN_ENCRYPTION_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────

# Public URL of your Jellybox install. Defaults to http://localhost:3000.
# Set this when you put Jellybox behind a reverse proxy with a real hostname.
# AUTH_URL=https://jellybox.your-home.example

# Postgres password for the bundled postgres service. Defaults to "jellybox".
# POSTGRES_PASSWORD=

# Email (Resend) — required for email sign-up / verification / password reset.
# Skip these if you only intend to use Google or OIDC sign-in.
# RESEND_API_KEY=
# EMAIL_FROM=Jellybox <noreply@your-domain.example>

# Google OAuth (optional)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Generic OIDC (optional). All three must be set for the SSO button to appear.
# AUTH_OIDC_ISSUER=
# AUTH_OIDC_ID=
# AUTH_OIDC_SECRET=
# AUTH_OIDC_NAME=SSO

# Comma-separated list of admin emails allowed to register extensions.
# Empty/unset = closed (no one can add extensions).
# ADMINS=you@example.com

# ─── Firmware OTA (optional) ─────────────────────────────────────────────────
# Override the GitHub repo the server polls for the firmware manifest, and/or
# pin every paired device to a specific release tag instead of always serving
# the latest GitHub release. Defaults: Nikorag/Jellybox-Firmware @ latest.
# FIRMWARE_REPO=Nikorag/Jellybox-Firmware
# FIRMWARE_VERSION=v0.0.2

# ─── Optional: Home Assistant scripts extension sidecar ──────────────────────
# Used only when you uncomment the jellybox-ha-extension service.
# HOMEASSISTANT_URL=http://homeassistant.local:8123
# JELLYBOX_HA_BEARER_SECRET=
