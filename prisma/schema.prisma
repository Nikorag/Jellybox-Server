// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth v5 required models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  jellyfinServer    JellyfinServer?
  jellyfinClients   JellyfinClient[]
  addedExtensions   Extension[]        @relation("AddedExtensions")
  extensionAccounts ExtensionAccount[]
  devices           Device[]
  rfidTags          RfidTag[]
  activityLogs      ActivityLog[]

  // Partners: users this account owner has granted access to their data
  ownedPartners AccountPartner[] @relation("OwnedPartners")
  // Partners: accounts this user has been granted access to
  partnerAccess AccountPartner[] @relation("PartnerAccess")

  // Operating hours (parental controls)
  operatingHoursEnabled  Boolean @default(false)
  operatingHoursStart    String? // "HH:MM" 24hr e.g. "07:00"
  operatingHoursEnd      String? // "HH:MM" 24hr e.g. "21:00"
  operatingHoursTimezone String? // IANA timezone e.g. "Europe/London"

  /// Grace period in seconds before the same device can trigger playback again
  scanDebounceSeconds Int @default(5)

  webhooks             Webhook[]
  notificationChannels NotificationChannel[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Jellyfin Integration ────────────────────────────────────────────────────

enum JellyfinServerStatus {
  CONNECTED
  UNREACHABLE
  AUTH_ERROR
  UNKNOWN
}

model JellyfinServer {
  id            String               @id @default(cuid())
  userId        String               @unique
  serverUrl     String
  /// AES-256-GCM encrypted Jellyfin API token (format: iv:authTag:ciphertext, all hex)
  apiToken      String
  /// AES-256-GCM encrypted JSON object of custom HTTP headers sent with every Jellyfin request
  customHeaders String?
  serverId      String?
  serverName    String?
  status        JellyfinServerStatus @default(UNKNOWN)
  lastCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients JellyfinClient[]

  @@map("jellyfin_servers")
}

model JellyfinClient {
  id               String   @id @default(cuid())
  userId           String
  jellyfinServerId String
  /// Jellyfin's persistent DeviceId (stable across sessions)
  jellyfinDeviceId String
  deviceName       String
  lastSeenAt       DateTime @default(now())

  createdAt DateTime @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jellyfinServer JellyfinServer @relation(fields: [jellyfinServerId], references: [id], onDelete: Cascade)
  devices        Device[]

  @@unique([jellyfinServerId, jellyfinDeviceId])
  @@map("jellyfin_clients")
}

// ─── Extensions ──────────────────────────────────────────────────────────────

/// System-wide third-party HTTP extension (e.g. Spotify, Plex, YouTube).
/// Registered once by an admin (gated by the ADMINS env var). Every user can
/// then connect their own account to it via ExtensionAccount.
/// Jellybox calls a fixed set of HTTP routes defined in src/lib/extensions/types.ts.
model Extension {
  id            String  @id @default(cuid())
  /// Human-readable name pulled from the extension's manifest at registration time.
  name          String
  /// Base URL the extension is served at (no trailing slash). All contract routes are relative to this.
  baseUrl       String
  /// AES-256-GCM encrypted shared secret sent as `Authorization: Bearer …` to the extension.
  /// One secret per extension — authenticates the Jellybox instance, not individual users.
  secret        String
  /// JSON snapshot of the manifest fetched at registration. Refreshed on demand from settings UI.
  manifest      Json
  enabled       Boolean @default(true)
  /// Audit only — which admin originally added this extension. Set to null when that user is deleted.
  addedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addedBy  User?              @relation("AddedExtensions", fields: [addedByUserId], references: [id], onDelete: SetNull)
  accounts ExtensionAccount[]
  rfidTags RfidTag[]

  @@map("extensions")
}

/// A specific user's connection to an extension (e.g. user A's Spotify account).
/// Jellybox stores only the opaque accountId — credentials live inside the extension.
model ExtensionAccount {
  id              String  @id @default(cuid())
  extensionId     String
  userId          String
  /// Opaque identifier returned by the extension's /authenticate/complete endpoint.
  accountId       String
  /// Display name shown in the UI ("jamie@spotify").
  displayName     String
  /// Opaque client identifier the user picked as the default playback target. Forwarded to /play.
  defaultClientId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extension Extension @relation(fields: [extensionId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([extensionId, userId])
  @@map("extension_accounts")
}

// ─── Physical Devices ────────────────────────────────────────────────────────

model Device {
  id              String    @id @default(cuid())
  userId          String
  name            String
  /// bcrypt hash of the raw API key
  apiKeyHash      String
  /// First 8 characters of the raw API key — for display only
  apiKeyPrefix    String
  defaultClientId String?
  lastSeenAt      DateTime?
  firmwareVersion String?
  /// When true, the next /api/device/me poll returns the latest firmware
  /// manifest, prompting an OTA. Cleared automatically once the device
  /// reports running the manifest version.
  firmwareUpdatePending Boolean @default(false)

  /// Set when device is in scan-capture mode; links back to a pending registration session
  scanModeToken     String?
  /// Scan mode auto-expires after this time
  scanModeExpiresAt DateTime?
  /// Tag UID written here when the device scans during scan-capture mode
  pendingScanTagId  String?
  /// Timestamp of the last successful play — used for debounce
  lastPlayedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultClient JellyfinClient? @relation(fields: [defaultClientId], references: [id], onDelete: SetNull)
  activityLogs  ActivityLog[]

  @@map("devices")
}

// ─── RFID Tags ───────────────────────────────────────────────────────────────

enum JellyfinItemType {
  MOVIE
  SERIES
  EPISODE
  ALBUM
  PLAYLIST
  UNKNOWN
}

model RfidTag {
  id     String @id @default(cuid())
  userId String
  /// Raw RFID hardware UID as reported by the device
  tagId  String
  label  String

  // Jellyfin content assignment (cached at assignment time)
  jellyfinItemId       String?
  jellyfinItemType     JellyfinItemType?
  jellyfinItemTitle    String?
  /// Jellyfin image tag for constructing artwork URL
  jellyfinItemImageTag String?

  // Extension-backed assignment (mutually exclusive with jellyfin* fields)
  extensionId          String?
  /// Opaque item identifier returned by the extension at search/get time.
  externalItemId       String?
  /// Free-form item type as reported by the extension (e.g. "track", "album").
  externalItemType     String?
  externalItemTitle    String?
  /// Opaque image identifier — passed back to the extension's /image route via the proxy.
  externalItemImageId  String?
  /// Direct image URL captured from the extension's MediaItem at assignment time.
  /// When set, the UI uses it as-is instead of falling back to the /image proxy.
  externalItemImageUrl String?

  /// For SERIES: play next unplayed episode instead of a random one
  resumePlayback Boolean @default(false)
  /// For SERIES/ALBUM/PLAYLIST: shuffle playback order
  shuffle        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  extension    Extension?    @relation(fields: [extensionId], references: [id], onDelete: SetNull)
  activityLogs ActivityLog[]

  // A tag ID must be unique per user
  @@unique([userId, tagId])
  @@map("rfid_tags")
}

// ─── Account Partners ────────────────────────────────────────────────────────

/// Grants partnerId read/write access to ownerId's tags and devices.
/// Partners cannot access Jellyfin settings.
model AccountPartner {
  id        String   @id @default(cuid())
  /// The account whose data is being shared
  ownerId   String
  /// The user being granted access
  partnerId String
  createdAt DateTime @default(now())

  owner   User @relation("OwnedPartners", fields: [ownerId], references: [id], onDelete: Cascade)
  partner User @relation("PartnerAccess", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, partnerId])
  @@map("account_partners")
}

// ─── Webhooks ────────────────────────────────────────────────────────────────

enum WebhookEvent {
  JELLYFIN_OFFLINE
  TAG_SCANNED
  PLAYBACK_FAILED
}

model Webhook {
  id                String       @id @default(cuid())
  userId            String
  label             String
  url               String
  event             WebhookEvent
  /// Seconds to wait after firing webhook before retrying the play command
  retryDelaySeconds Int          @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

// ─── Notifications ───────────────────────────────────────────────────────────

enum NotificationType {
  NTFY
  DISCORD
  SLACK
}

enum NotificationEvent {
  TAG_SCANNED
  PLAYBACK_FAILED
}

model NotificationChannel {
  id      String              @id @default(cuid())
  userId  String
  type    NotificationType
  label   String
  enabled Boolean             @default(true)
  events  NotificationEvent[]
  /// AES-256-GCM encrypted JSON config (shape varies by type)
  config  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_channels")
}

// ─── Activity Logs ───────────────────────────────────────────────────────────

model ActivityLog {
  id        String  @id @default(cuid())
  userId    String
  deviceId  String?
  rfidTagId String?

  // Snapshots captured at log time (survive deletions)
  deviceName        String
  tagId             String
  jellyfinItemTitle String?

  success   Boolean
  /// Error code when success = false: UNASSIGNED | OFFLINE | AUTH_ERROR | RATE_LIMITED | OUTSIDE_HOURS | NO_CLIENT | UNKNOWN
  errorCode String?

  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device  Device?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  rfidTag RfidTag? @relation(fields: [rfidTagId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([deviceId, createdAt(sort: Desc)])
  @@map("activity_logs")
}
