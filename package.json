    "@vitejs/plugin-react": "^6.0.1",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^16.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.49",
    "prisma": "^6.3.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.2.5",
